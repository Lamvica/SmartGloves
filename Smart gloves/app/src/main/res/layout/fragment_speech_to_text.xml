<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".ui.speechtotext.SpeechToTextFragment">

    <TextView
        android:id="@+id/label_speech_to_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/speech_to_text"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/purple_dark"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/button_speech_toggle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/start_listening"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/purple_dark"
        android:padding="16dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/label_speech_to_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/text_speech_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/speech_result"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        android:minHeight="120dp"
        android:background="@android:color/white"
        android:gravity="top|start"
        android:scrollbars="vertical"
        android:maxLines="10"
        android:overScrollMode="always"
        app:layout_constraintTop_toBottomOf="@id/button_speech_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

