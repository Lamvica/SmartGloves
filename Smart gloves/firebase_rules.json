{
  "rules": {
    "gestures": {
      ".read": true,
      ".write": true
    },
    "history": {
      ".read": true,
      ".write": true
    },
    "categories": {
      ".read": true,
      ".write": true,
      "$cat": {
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "nextId": {
          ".validate": "newData.isNumber() && newData.val() >= 1"
        }
      }
    },
    "speechHistory": {
      ".read": true,
      ".write": true
    },
    "wavFiles": {
      ".read": true,
      ".write": true
    },
    "users": {
      "$userId": {
        ".read": true,
        ".write": true,
        "profile": {
          ".read": true,
          ".write": true
        },
        "gestures": {
          ".read": true,
          ".write": true
        },
        "categories": {
          ".read": true,
          ".write": true
        },
        "history": {
          ".read": true,
          ".write": true
        },
        "speechHistory": {
          ".read": true,
          ".write": true
        },
        "wavFiles": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}